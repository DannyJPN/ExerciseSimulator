{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trainer Avatar Simulator Asset Manifest",
  "type": "object",
  "required": [
    "asset_id",
    "category",
    "display_name",
    "source_tool",
    "license",
    "author",
    "scale_unit",
    "target_pipeline",
    "files"
  ],
  "properties": {
    "asset_id": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "avatar_body",
        "clothing",
        "animation",
        "environment_prop",
        "environment_surface",
        "material_pack"
      ]
    },
    "display_name": { "type": "string" },
    "source_tool": { "type": "string" },
    "license": { "type": "string" },
    "author": { "type": "string" },
    "scale_unit": {
      "type": "string",
      "enum": ["meter", "centimeter", "millimeter"]
    },
    "target_pipeline": {
      "type": "string",
      "enum": ["unity_hdrp"]
    },
    "slot": {
      "type": "string",
      "enum": ["top", "bottom", "shoes", "socks"]
    },
    "rig_type": {
      "type": "string",
      "enum": ["humanoid", "generic", "none"]
    },
    "technical_notes": { "type": "string" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["mesh", "texture", "animation", "material", "preview", "document"]
          }
        }
      }
    }
  }
}
